# Tracked, non-secret defaults for clean clones and CI.
# Production secrets should be injected through a safer build process.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
PICOVOICE_ACCESS_KEY=
YANDEX_MAPKIT_API_KEY=
DGIS_API_KEY=

# Non-secret runtime defaults bundled with the app.
WAKE_ENGINE=stt_android
STT_WAKE_ENABLED=true
STT_WAKE_LANGUAGE=ru-RU
STT_WAKE_PARTIAL_RESULTS_ENABLED=true
STT_WAKE_PREFER_OFFLINE=false
STT_WAKE_LEGACY_FALLBACK_ENABLED=true
WAKE_RECALL_MODE=max_recall
TEXT_READER_FRAME_INTERVAL_MS=550
TEXT_READER_SPEECH_COOLDOWN_MS=900
TEXT_READER_STABLE_FRAMES=3
